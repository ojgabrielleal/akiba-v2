<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    
    # Subdomains Rules -----------------------------------------------

    RewriteCond %{HTTP_HOST} ^(www\.)?painel\.akiba\.com\.br$ [NC]
	RewriteRule ^(.*)$ https\:\/\/www\.akiba\.com\.br\/panel [R=301,L]
    
    RewriteCond %{HTTP_HOST} ^(www\.)?stream\.akiba\.com\.br$ [NC]
	RewriteRule ^(.*)$ https\:\/\/www\.akiba\.com\.br\/api\/cast [R=301,L]
    
    RewriteCond %{HTTP_HOST} ^(www\.)?discord\.akiba\.com\.br$ [NC]
	RewriteRule ^(.*)$ https\:\/\/www\.discord\.com\/invite\/akGhEMb [R=301,L]
    
    # Observation --------------------
    # Default Correct Rule: RewriteRule ^(.*)$ https\:\/\/www\.akiba\.com\.br\/$1 [R=301,L]
    # Observation --------------------

    # Subdomains Rules -----------------------------------------------
   
    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-SSL} !on
RewriteCond %{HTTP_HOST} ^akiba\.com\.br$ [OR]
RewriteCond %{HTTP_HOST} ^www\.akiba\.com\.br$
RewriteRule ^(.*)$ "https\:\/\/www\.akiba\.com\.br\/$1" [R=301,L]

# HOSTING CONFIGURATION -----------------------------------------------

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# HOSTING CONFIGURATION -----------------------------------------------
